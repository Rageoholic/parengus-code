{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"command": "build",
			"problemMatcher": [
				"$rustc"
			],
			"group": "build",
			"label": "rust: cargo build debug"
		},
		{
			"type": "cargo",
			"command": "test",
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"label": "rust: cargo test debug"
		},
		{
			"type": "cargo",
			"command": "clippy",
			"problemMatcher": [
				"$rustc"
			],
			"label": "rust: cargo clippy"
		},
		{
			"label": "build all debug",
			"type": "shell",
			"command": "cargo xtask build",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "build samp-app debug",
			"type": "shell",
			"command": "cargo xtask build-samp-app"
		},
		{
			"label": "build phoenix debug",
			"type": "shell",
			"command": "cargo xtask build-phoenix"
		},
		{
			"label": "build samp-app-noext debug",
			"type": "shell",
			"command": "cargo xtask build-samp-app-noext"
		},
	]
}