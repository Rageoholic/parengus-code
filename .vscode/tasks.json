{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"command": "build",
			"problemMatcher": [
				"$rustc"
			],
			"group": "build",
			"label": "rust: cargo build debug"
		},
		{
			"type": "cargo",
			"command": "test",
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"label": "rust: cargo test debug"
		},
		{
			"type": "shell",
			"label": "copy executable to game dir (debug)",
			"command": "cargo xtask copy-exe",
			"dependsOn": "rust: cargo build debug"
		},
		{
			"type": "cargo",
			"command": "clippy",
			"problemMatcher": [
				"$rustc"
			],
			"label": "rust: cargo clippy"
		},
		{
			"type": "shell",
			"label": "compile shaders (debug)",
			"command": "cargo xtask compile-shaders"
		},
		{
			"label": "build samp-app debug",
			"type": "shell",
			"command": "cargo xtask build",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
	]
}