    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) Launch samp-app",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/samp-app/debug/samp-app.exe",
            "args": [
                "--tracing-log-level",
                "warn",
                "--graphics-debug-level",
                "warn"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}/out/samp-app/debug/",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "build samp-app debug"
        },
        {
            "name": "(Windows) Launch samp-app (errors only)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/samp-app/debug/samp-app.exe",
            "args": [
                "--graphics-debug-level",
                "error"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}/out/samp-app/debug/",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "build samp-app debug"
        },
